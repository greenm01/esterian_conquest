// Solarized Dark for ec-game
// altercation/vim-colors-solarized
//
// Background: #002b36  Foreground: #839496
// The precision low-contrast classic — thoughtful, timeless, influential.

style "body" {
    fg "#839496"
    bg "#002b36"
}
style "title" {
    fg "#268bd2"
    bg "#002b36"
    bold #true
}
style "menu" {
    fg "#839496"
    bg "#002b36"
}
style "menu_hotkey" {
    fg "#b58900"
    bg "#002b36"
    bold #true
}
style "prompt" {
    fg "#839496"
    bg "#002b36"
}
style "prompt_hotkey" {
    fg "#b58900"
    bg "#002b36"
    bold #true
}
style "prompt_notice_action" {
    fg "#2aa198"
    bg "#002b36"
    bold #true
}
style "bright" {
    fg "#93a1a1"
    bg "#002b36"
    bold #true
}
style "logo" {
    fg "#268bd2"
    bg "#002b36"
    bold #true
}
style "intro_accent" {
    fg "#268bd2"
    bg "#002b36"
}
style "intro_tribute" {
    fg "#d33682"
    bg "#002b36"
}
