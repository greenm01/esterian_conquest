    fg "#2aa198"
    bg "#002b36"
    bold #true
}
style "stardate_year" {
    fg "#b58900"
    bg "#002b36"
}
style "error" {
    fg "#dc322f"
    bg "#002b36"
    bold #true
}
style "notice" {
    fg "#dc322f"
    bg "#002b36"
    bold #true
}
style "status_label" {
    fg "#586e75"
    bg "#002b36"
}
style "status_value" {
    fg "#839496"
    bg "#002b36"
}
style "table_chrome" {
    fg "#073642"
    bg "#002b36"
}
style "table_header" {
    fg "#268bd2"
    bg "#002b36"
    bold #true
}
style "table_body" {
    fg "#93a1a1"
    bg "#002b36"
}
style "disabled_row" {
    fg "#586e75"
    bg "#002b36"
}
style "selected" {
    fg "#002b36"
    bg "#268bd2"
}
style "alert" {
    fg "#fdf6e3"
    bg "#dc322f"
    bold #true
}
style "help_header" {
    fg "#268bd2"
    bg "#002b36"
    bold #true
}
style "help_panel" {
    fg "#839496"
    bg "#002b36"
}
style "map_dot" {
    fg "#859900"
    bg "#002b36"
}
style "map_crosshair" {
    fg "#dc322f"
    bg "#002b36"
    bold #true
}
style "map_center" {
    fg "#93a1a1"
    bg "#002b36"
    bold #true
}
style "quote" {
    fg "#586e75"
    bg "#002b36"
}
style "quote_author" {
    fg "#586e75"
    bg "#002b36"
}
style "report_header" {
    fg "#2aa198"
    bg "#002b36"
}
