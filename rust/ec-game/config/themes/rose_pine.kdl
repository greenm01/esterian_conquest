// Rose Pine (Main) for ec-game
// rose-pine/neovim
//
// Background: #191724  Foreground: #e0def4
// Soft, minimalist soho aesthetic — gentle tones, deeply calming.

style "body" {
    fg "#e0def4"
    bg "#191724"
}
