// Matrix theme for ec-game / ec-connect
//
// Derived from iruzo/matrix-nvim (MIT)
// https://github.com/iruzo/matrix-nvim
//
// Background: #0D0208 (near-black)
// Foreground: #55ff55 (bright matrix green)
//
// Palette (dark variant from lua/matrix/colors.lua):
//   matrix0  #0D0208  near-black bg
//   matrix1  #113311  dark green-black
//   matrix2  #003B00  deep green
//   matrix3  #226622  muted green
//   matrix4  #55ff55  bright green (fg)
//   matrix5  #00FF41  matrix green
//   matrix7  #339955  mid green
//   matrix8  #339933  green accent
//   matrix9  #008F11  dark green accent
//   matrix11 #ff0000  red (error/danger)
//   matrix13 #FFFF00  yellow (hotkeys/warnings)
//   matrix15 #E4D00A  gold

style "body" {
    fg "#55ff55"
    bg "#0D0208"
}
style "title" {
    fg "#008F11"
    bg "#0D0208"
    bold #true
}
style "shell_title" {
    fg "#339933"
    bg "#0D0208"
    bold #true
}
style "shell_label" {
    fg "#339955"
    bg "#0D0208"
    bold #true
}
style "menu" {
    fg "#55ff55"
    bg "#0D0208"
}
style "menu_hotkey" {
    fg "#FFFF00"
    bg "#0D0208"
    bold #true
}
style "prompt" {
    fg "#55ff55"
    bg "#0D0208"
}
style "prompt_angle_delimiter" {
    fg "#00FF41"
    bg "#0D0208"
    bold #true
}
style "prompt_square_delimiter" {
    fg "#ff0000"
    bg "#0D0208"
    bold #true
}
style "prompt_hotkey" {
    fg "#FFFF00"
    bg "#0D0208"
    bold #true
}
style "prompt_notice_action" {
    fg "#339933"
    bg "#0D0208"
    bold #true
}
style "bright" {
    fg "#00FF41"
    bg "#0D0208"
    bold #true
}
style "logo" {
    fg "#008F11"
    bg "#0D0208"
    bold #true
}
style "intro_accent" {
    fg "#008F11"
    bg "#0D0208"
}
style "intro_tribute" {
    fg "#339955"
    bg "#0D0208"
}
style "stardate_label" {
    fg "#339933"
    bg "#0D0208"
}
style "stardate_week" {
    fg "#339933"
    bg "#0D0208"
    bold #true
}
style "stardate_year" {
    fg "#FFFF00"
    bg "#0D0208"
}
style "error" {
    fg "#ff0000"
    bg "#0D0208"
    bold #true
}
style "notice" {
    fg "#ff0000"
    bg "#0D0208"
    bold #true
}
style "status_label" {
    fg "#226622"
    bg "#0D0208"
}
style "status_value" {
    fg "#55ff55"
    bg "#0D0208"
}
style "table_chrome" {
    fg "#003B00"
    bg "#0D0208"
}
style "table_header" {
    fg "#008F11"
    bg "#0D0208"
    bold #true
}
style "table_body" {
    fg "#00FF41"
    bg "#0D0208"
}
style "disabled_row" {
    fg "#226622"
    bg "#0D0208"
}
style "selected" {
    fg "#0D0208"
    bg "#008F11"
}
style "alert" {
    fg "#ff0000"
    bg "#113311"
    bold #true
}
style "help_header" {
    fg "#008F11"
    bg "#0D0208"
    bold #true
}
style "help_panel" {
    fg "#55ff55"
    bg "#0D0208"
}
style "map_dot" {
    fg "#00FF41"
    bg "#0D0208"
}
style "map_crosshair" {
    fg "#ff0000"
    bg "#0D0208"
    bold #true
}
style "map_center" {
    fg "#55ff55"
    bg "#0D0208"
    bold #true
}
style "quote" {
    fg "#226622"
    bg "#0D0208"
}
style "quote_author" {
    fg "#226622"
    bg "#0D0208"
}
style "report_header" {
    fg "#339933"
    bg "#0D0208"
}
style "indicator_on" {
    fg "#00FF41"
    bg "#0D0208"
    bold #true
}
style "indicator_off" {
    fg "#003B00"
    bg "#0D0208"
}

star-colors "#008F11" "#00FF41" "#55ff55" "#339933" "#E4D00A" "#ff0000"
