}
style "help_header" {
    fg "#7fbbb3"
    bg "#2d353b"
    bold #true
}
style "help_panel" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "map_dot" {
    fg "#a7c080"
    bg "#2d353b"
}
style "map_crosshair" {
    fg "#e67e80"
    bg "#2d353b"
    bold #true
}
style "map_center" {
    fg "#d3c6aa"
    bg "#2d353b"
    bold #true
}
style "quote" {
    fg "#7a8478"
