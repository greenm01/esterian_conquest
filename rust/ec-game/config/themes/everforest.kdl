// Everforest Dark (medium contrast) for ec-game
// sainnhe/everforest
//
// Background: #2d353b  Foreground: #d3c6aa
// Warm forest-inspired greens — comfortable for long sessions, easy on the eyes.

style "body" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "title" {
    fg "#7fbbb3"
    bg "#2d353b"
    bold #true
}
style "menu" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "menu_hotkey" {
    fg "#dbbc7f"
    bg "#2d353b"
    bold #true
}
style "prompt" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "prompt_hotkey" {
    fg "#dbbc7f"
    bg "#2d353b"
    bold #true
}
style "prompt_notice_action" {
    fg "#83c092"
    bg "#2d353b"
    bold #true
}
style "bright" {
    fg "#d3c6aa"
    bg "#2d353b"
    bold #true
}
style "logo" {
    fg "#7fbbb3"
    bg "#2d353b"
    bold #true
}
style "intro_accent" {
    fg "#7fbbb3"
    bg "#2d353b"
}
