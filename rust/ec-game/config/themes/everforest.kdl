    fg "#83c092"
    bg "#2d353b"
    bold #true
}
style "stardate_year" {
    fg "#dbbc7f"
    bg "#2d353b"
}
style "error" {
    fg "#e67e80"
    bg "#2d353b"
    bold #true
}
style "notice" {
    fg "#e67e80"
    bg "#2d353b"
    bold #true
}
style "status_label" {
    fg "#859289"
    bg "#2d353b"
}
style "status_value" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "table_chrome" {
    fg "#475258"
    bg "#2d353b"
}
style "table_header" {
    fg "#7fbbb3"
    bg "#2d353b"
    bold #true
}
style "table_body" {
    fg "#d3c6aa"
    bg "#2d353b"
}
style "disabled_row" {
    fg "#7a8478"
    bg "#2d353b"
}
