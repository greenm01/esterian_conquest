// Nord for ec-game
// arcticicestudio/nord-vim
//
// Background: #2E3440  Foreground: #D8DEE9
// Arctic, clean blue-toned — elegant, minimalist, and consistent.

style "body" {
    fg "#D8DEE9"
    bg "#2E3440"
}
style "title" {
    fg "#81A1C1"
    bg "#2E3440"
    bold #true
}
style "menu" {
    fg "#D8DEE9"
    bg "#2E3440"
}
style "menu_hotkey" {
    fg "#EBCB8B"
    bg "#2E3440"
    bold #true
}
style "prompt" {
    fg "#D8DEE9"
    bg "#2E3440"
}
style "prompt_angle_delimiter" {
    fg "#A3BE8C"
    bg "#2E3440"
    bold #true
}
style "prompt_square_delimiter" {
    fg "#BF616A"
    bg "#2E3440"
    bold #true
}
style "prompt_hotkey" {
    fg "#EBCB8B"
    bg "#2E3440"
    bold #true
}
style "prompt_notice_action" {
    fg "#88C0D0"
    bg "#2E3440"
    bold #true
}
style "bright" {
    fg "#ECEFF4"
    bg "#2E3440"
    bold #true
}
style "logo" {
    fg "#81A1C1"
    bg "#2E3440"
    bold #true
}
style "intro_accent" {
    fg "#81A1C1"
    bg "#2E3440"
}
style "intro_tribute" {
    fg "#B48EAD"
    bg "#2E3440"
}
style "stardate_label" {
    fg "#88C0D0"
    bg "#2E3440"
}
style "stardate_week" {
    fg "#88C0D0"
    bg "#2E3440"
    bold #true
}
style "stardate_year" {
    fg "#EBCB8B"
    bg "#2E3440"
}
style "error" {
    fg "#BF616A"
    bg "#2E3440"
    bold #true
}
style "notice" {
    fg "#BF616A"
    bg "#2E3440"
    bold #true
}
style "status_label" {
    fg "#4C566A"
    bg "#2E3440"
}
style "status_value" {
    fg "#D8DEE9"
    bg "#2E3440"
}
style "table_chrome" {
    fg "#3B4252"
    bg "#2E3440"
}
style "table_header" {
    fg "#81A1C1"
    bg "#2E3440"
    bold #true
}
style "table_body" {
    fg "#E5E9F0"
    bg "#2E3440"
}
style "disabled_row" {
    fg "#4C566A"
    bg "#2E3440"
}
style "selected" {
    fg "#2E3440"
    bg "#81A1C1"
}
style "alert" {
    fg "#D8DEE9"
    bg "#BF616A"
    bold #true
}
style "help_header" {
    fg "#81A1C1"
    bg "#2E3440"
    bold #true
}
style "help_panel" {
    fg "#D8DEE9"
    bg "#2E3440"
}
style "map_dot" {
    fg "#A3BE8C"
    bg "#2E3440"
}
style "map_crosshair" {
    fg "#BF616A"
    bg "#2E3440"
    bold #true
}
style "map_center" {
    fg "#ECEFF4"
    bg "#2E3440"
    bold #true
}
style "quote" {
    fg "#616E88"
    bg "#2E3440"
}
style "quote_author" {
    fg "#616E88"
    bg "#2E3440"
}
style "report_header" {
    fg "#88C0D0"
    bg "#2E3440"
}
style "indicator_on" {
    fg "#A3BE8C"
    bg "#2E3440"
    bold #true
}
style "indicator_off" {
    fg "#3B4252"
    bg "#2E3440"
}

star-colors "#81A1C1" "#ECEFF4" "#E5E9F0" "#EBCB8B" "#D08770" "#BF616A"
