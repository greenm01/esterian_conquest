// Mag16 — ANSI-16 native theme for BBS, SyncTERM, and CP437 door terminals
//
// Uses only named 16-color ANSI values. No hex, no indexed. This is the
// baseline theme for classic DOS-style presentation with zero downgrade loss.

style "body" {
    fg "white"
    bg "black"
}
style "title" {
    fg "bright_blue"
    bg "black"
    bold #true
}
style "menu" {
    fg "white"
    bg "black"
}
style "menu_hotkey" {
    fg "yellow"
    bg "black"
    bold #true
}
style "prompt" {
    fg "white"
    bg "black"
}
style "prompt_hotkey" {
    fg "yellow"
    bg "black"
    bold #true
}
style "prompt_notice_action" {
    fg "bright_cyan"
    bg "black"
    bold #true
}
style "bright" {
    fg "bright_white"
    bg "black"
    bold #true
}
style "logo" {
    fg "bright_blue"
    bg "black"
    bold #true
}
style "intro_accent" {
    fg "bright_blue"
    bg "black"
}
style "intro_tribute" {
    fg "bright_magenta"
    bg "black"
}
style "stardate_label" {
    fg "cyan"
    bg "black"
}
style "stardate_week" {
    fg "bright_cyan"
    bg "black"
}
style "stardate_year" {
    fg "yellow"
    bg "black"
}
style "error" {
    fg "red"
    bg "black"
    bold #true
}
style "notice" {
    fg "bright_red"
    bg "black"
    bold #true
}
style "status_label" {
    fg "white"
    bg "black"
}
style "status_value" {
    fg "white"
    bg "black"
}
style "table_chrome" {
    fg "blue"
    bg "black"
}
style "table_header" {
    fg "cyan"
    bg "black"
    bold #true
}
style "table_body" {
    fg "light_grey"
    bg "black"
}
style "disabled_row" {
    fg "bright_black"
    bg "black"
}
style "selected" {
    fg "bright_white"
    bg "cyan"
}
style "alert" {
    fg "bright_white"
    bg "red"
    bold #true
}
style "help_header" {
    fg "bright_blue"
    bg "black"
    bold #true
}
style "help_panel" {
    fg "white"
    bg "black"
}
style "map_dot" {
    fg "green"
    bg "black"
}
style "map_crosshair" {
    fg "bright_red"
    bg "black"
    bold #true
}
style "map_center" {
    fg "bright_white"
    bg "black"
    bold #true
}
style "quote" {
    fg "white"
    bg "black"
}
style "quote_author" {
    fg "white"
    bg "black"
}
style "report_header" {
    fg "cyan"
    bg "black"
}
style "indicator_on" {
    fg "bright_green"
    bg "black"
    bold #true
}
style "indicator_off" {
    fg "bright_black"
    bg "black"
}

star-colors "bright_blue" "bright_white" "white" "bright_yellow" "yellow" "bright_red"
