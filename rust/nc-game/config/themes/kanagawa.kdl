// Kanagawa Wave for nc-game
// rebelot/kanagawa.nvim
//
// Background: #1F1F28  Foreground: #DCD7BA
// Art-inspired (Hokusai waves) — beautiful, balanced, and deeply readable.

style "body" {
    fg "#DCD7BA"
    bg "#1F1F28"
}
style "title" {
    fg "#7E9CD8"
    bg "#1F1F28"
    bold #true
}
