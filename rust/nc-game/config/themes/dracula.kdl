// Dracula for nc-game
// dracula/vim
//
// Background: #282A36  Foreground: #F8F8F2
// Bold, iconic purple/pink — vibrant without being chaotic.

style "body" {
    fg "#F8F8F2"
    bg "#282A36"
}
style "title" {
    fg "#BD93F9"
    bg "#282A36"
    bold #true
}
