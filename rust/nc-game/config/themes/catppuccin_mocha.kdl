// Catppuccin Mocha for nc-game
// catppuccin/nvim
//
// Background: #1e1e2e  Foreground: #cdd6f4
// Soothing pastels with a cozy, modern dark aesthetic.

style "body" {
    fg "#cdd6f4"
    bg "#1e1e2e"
}
style "title" {
    fg "#89b4fa"
    bg "#1e1e2e"
    bold #true
}
