meta name="Kanagawa Lotus" author="rebelot" variant="light" version="1.0" description="Light theme inspired by the serenity of a lotus pond"

palette "sumi_ink0" "#d5cea3"
palette "sumi_ink1" "#dcd5ac"
palette "sumi_ink3" "#f2ecbc"
palette "sumi_ink4" "#e7dba0"
palette "sumi_ink5" "#e4d794"
palette "sumi_ink6" "#8a8980"
palette "fuji_white" "#545464"
palette "old_white" "#716e61"
palette "fuji_gray" "#8a8980"
palette "crystal_blue" "#4d699b"
palette "oni_violet" "#624c83"
palette "spring_violet1" "#a09cac"
palette "spring_violet2" "#766b90"
palette "spring_blue" "#5d57a3"
palette "spring_green" "#6f894e"
palette "carp_yellow" "#77713f"
palette "boat_yellow2" "#836f4a"
palette "sakura_pink" "#b35b79"
palette "wave_red" "#c84053"
palette "peach_red" "#d7474b"
palette "surimi_orange" "#cc6d00"
palette "wave_aqua2" "#597b75"
palette "samurai_red" "#e82424"
palette "ronin_yellow" "#de9800"
palette "autumn_green" "#6e915f"
palette "autumn_red" "#c84053"
palette "autumn_yellow" "#e98a00"

token "text.primary" "fuji_white"
token "text.secondary" "old_white"
token "text.muted" "fuji_gray"
token "text.dim" "sumi_ink6"
token "bg.base" "sumi_ink3"
token "bg.panel" "sumi_ink1"
token "bg.code" "sumi_ink0"
token "bg.highlight" "sumi_ink4"
token "bg.elevated" "sumi_ink5"
token "bg.active" "sumi_ink5"
token "bg.selection" "sumi_ink4"
token "accent.primary" "oni_violet"
token "accent.secondary" "crystal_blue"
token "accent.tertiary" "sakura_pink"
token "accent.deep" "spring_violet1"
token "success" "spring_green"
token "error" "peach_red"
token "warning" "ronin_yellow"
token "info" "spring_blue"
token "border.focused" "crystal_blue"
token "border.unfocused" "sumi_ink6"
token "code.keyword" "oni_violet"
token "code.function" "crystal_blue"
token "code.string" "spring_green"
token "code.number" "sakura_pink"
token "code.comment" "fuji_gray"
token "code.type" "carp_yellow"
token "code.line_number" "sumi_ink6"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "oni_violet" "crystal_blue"
gradient "warm" "wave_red" "carp_yellow"
gradient "success_gradient" "spring_green" "wave_aqua2"
gradient "error_gradient" "peach_red" "sakura_pink"
gradient "aurora" "oni_violet" "crystal_blue" "spring_blue" "wave_aqua2" "spring_green"
