meta name="Catppuccin Latte" author="Catppuccin" variant="light" version="1.0" description="Soothing pastel theme for daylight lovers"

palette "base" "#eff1f5"
palette "mantle" "#e6e9ef"
palette "crust" "#dce0e8"
palette "surface0" "#ccd0da"
palette "surface1" "#bcc0cc"
palette "surface2" "#acb0be"
palette "overlay0" "#9ca0b0"
palette "overlay1" "#8c8fa1"
palette "overlay2" "#7c7f93"
palette "text" "#4c4f69"
palette "subtext1" "#5c5f77"
palette "subtext0" "#6c6f85"
palette "rosewater" "#dc8a78"
palette "flamingo" "#dd7878"
palette "pink" "#ea76cb"
palette "mauve" "#8839ef"
palette "red" "#d20f39"
palette "maroon" "#e64553"
palette "peach" "#fe640b"
palette "yellow" "#df8e1d"
palette "green" "#40a02b"
palette "teal" "#179299"
palette "sky" "#04a5e5"
palette "sapphire" "#209fb5"
palette "blue" "#1e66f5"
palette "lavender" "#7287fd"

token "text.primary" "text"
token "text.secondary" "subtext1"
token "text.muted" "subtext0"
token "text.dim" "overlay1"
token "bg.base" "base"
token "bg.panel" "mantle"
token "bg.code" "crust"
token "bg.highlight" "surface0"
token "bg.elevated" "surface1"
token "bg.active" "surface2"
token "bg.selection" "surface1"
token "accent.primary" "mauve"
token "accent.secondary" "sapphire"
token "accent.tertiary" "pink"
token "accent.deep" "lavender"
token "success" "green"
token "error" "red"
token "warning" "yellow"
token "info" "sky"
token "border.focused" "mauve"
token "border.unfocused" "surface2"
token "code.keyword" "mauve"
token "code.function" "blue"
token "code.string" "green"
token "code.number" "peach"
token "code.comment" "overlay1"
token "code.type" "yellow"
token "code.line_number" "overlay0"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "mauve" "sapphire"
gradient "warm" "peach" "yellow"
gradient "success_gradient" "green" "teal"
gradient "error_gradient" "red" "maroon"
gradient "aurora" "mauve" "pink" "sapphire" "teal" "green"
