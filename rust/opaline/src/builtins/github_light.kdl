meta name="GitHub Light" author="Primer" variant="light" version="1.0" description="GitHub's clean light default theme"

palette "canvas_default" "#ffffff"
palette "canvas_overlay" "#ffffff"
palette "canvas_inset" "#f6f8fa"
palette "canvas_subtle" "#f6f8fa"
palette "fg_default" "#1f2328"
palette "fg_muted" "#656d76"
palette "fg_subtle" "#6e7781"
palette "fg_on_emphasis" "#ffffff"
palette "border_default" "#d0d7de"
palette "border_muted" "#d0d7de"
palette "blue4" "#218bff"
palette "blue5" "#0969da"
palette "blue6" "#0550ae"
palette "blue8" "#0a3069"
palette "green4" "#2da44e"
palette "green5" "#1a7f37"
palette "green6" "#116329"
palette "red4" "#fa4549"
palette "red5" "#cf222e"
palette "red6" "#a40e26"
palette "yellow4" "#bf8700"
palette "yellow5" "#9a6700"
palette "orange4" "#e16f24"
palette "orange5" "#bc4c00"
palette "purple5" "#8250df"
palette "purple6" "#6639ba"
palette "pink5" "#bf3989"
palette "gray4" "#8c959f"
palette "gray5" "#6e7781"
palette "gray6" "#57606a"
palette "syn_comment" "#57606a"
palette "syn_constant" "#0550ae"
palette "syn_entity" "#6639ba"
palette "syn_entity_tag" "#116329"
palette "syn_keyword" "#cf222e"
palette "syn_string" "#0a3069"
palette "syn_variable" "#953800"

token "text.primary" "fg_default"
token "text.secondary" "fg_muted"
token "text.muted" "fg_subtle"
token "text.dim" "gray4"
token "bg.base" "canvas_default"
token "bg.panel" "canvas_default"
token "bg.code" "canvas_inset"
token "bg.highlight" "canvas_subtle"
token "bg.elevated" "canvas_subtle"
token "bg.active" "border_default"
token "bg.selection" "canvas_subtle"
token "accent.primary" "blue5"
token "accent.secondary" "purple5"
token "accent.tertiary" "pink5"
token "accent.deep" "blue6"
token "success" "green5"
token "error" "red5"
token "warning" "yellow5"
token "info" "blue5"
token "border.focused" "blue5"
token "border.unfocused" "border_default"
token "code.keyword" "syn_keyword"
token "code.function" "syn_entity"
token "code.string" "syn_string"
token "code.number" "syn_constant"
token "code.comment" "syn_comment"
token "code.type" "yellow5"
token "code.line_number" "gray4"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "blue5" "purple5"
gradient "warm" "orange5" "yellow5"
gradient "success_gradient" "green5" "green4"
gradient "error_gradient" "red5" "orange4"
gradient "aurora" "blue5" "purple5" "pink5" "green5" "yellow5"
