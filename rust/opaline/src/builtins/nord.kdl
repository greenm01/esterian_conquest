meta name="Nord" author="Arctic Ice Studio" variant="dark" version="1.0" description="An arctic, north-bluish clean and elegant palette"

palette "nord0" "#2e3440"
palette "nord1" "#3b4252"
palette "nord2" "#434c5e"
palette "nord3" "#4c566a"
palette "nord4" "#d8dee9"
palette "nord5" "#e5e9f0"
palette "nord6" "#eceff4"
palette "nord7" "#8fbcbb"
palette "nord8" "#88c0d0"
palette "nord9" "#81a1c1"
palette "nord10" "#5e81ac"
palette "nord11" "#bf616a"
palette "nord12" "#d08770"
palette "nord13" "#ebcb8b"
palette "nord14" "#a3be8c"
palette "nord15" "#b48ead"
palette "bg_dark" "#242933"
palette "fg_dim" "#a5abb6"

token "text.primary" "nord6"
token "text.secondary" "nord5"
token "text.muted" "nord4"
token "text.dim" "nord3"
token "bg.base" "bg_dark"
token "bg.panel" "nord0"
token "bg.code" "nord0"
token "bg.highlight" "nord1"
token "bg.elevated" "nord2"
token "bg.active" "nord3"
token "bg.selection" "nord2"
token "accent.primary" "nord8"
token "accent.secondary" "nord9"
token "accent.tertiary" "nord15"
token "accent.deep" "nord10"
token "success" "nord14"
token "error" "nord11"
token "warning" "nord13"
token "info" "nord8"
token "border.focused" "nord8"
token "border.unfocused" "nord3"
token "code.keyword" "nord9"
token "code.function" "nord8"
token "code.string" "nord14"
token "code.number" "nord15"
token "code.comment" "nord3"
token "code.type" "nord7"
token "code.line_number" "nord3"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "nord9" "nord8"
gradient "warm" "nord12" "nord13"
gradient "success_gradient" "nord14" "nord7"
gradient "error_gradient" "nord11" "nord12"
gradient "aurora" "nord15" "nord11" "nord12" "nord13" "nord14"
