meta name="Gruvbox Dark" author="morhetz" variant="dark" version="1.0" description="Retro groove color scheme with warm earthy tones"

palette "bg0_h" "#1d2021"
palette "bg0" "#282828"
palette "bg1" "#3c3836"
palette "bg2" "#504945"
palette "bg3" "#665c54"
palette "bg4" "#7c6f64"
palette "fg0" "#fbf1c7"
palette "fg1" "#ebdbb2"
palette "fg2" "#d5c4a1"
palette "fg3" "#bdae93"
palette "fg4" "#a89984"
palette "gray" "#928374"
palette "red" "#fb4934"
palette "green" "#b8bb26"
palette "yellow" "#fabd2f"
palette "blue" "#83a598"
palette "purple" "#d3869b"
palette "aqua" "#8ec07c"
palette "orange" "#fe8019"
palette "red_dim" "#cc241d"
palette "green_dim" "#98971a"
palette "yellow_dim" "#d79921"
palette "blue_dim" "#458588"
palette "purple_dim" "#b16286"
palette "aqua_dim" "#689d6a"
palette "orange_dim" "#d65d0e"

token "text.primary" "fg1"
token "text.secondary" "fg2"
token "text.muted" "fg3"
token "text.dim" "fg4"
token "bg.base" "bg0_h"
token "bg.panel" "bg0"
token "bg.code" "bg0"
token "bg.highlight" "bg1"
token "bg.elevated" "bg2"
token "bg.active" "bg3"
token "bg.selection" "bg2"
token "accent.primary" "orange"
token "accent.secondary" "aqua"
token "accent.tertiary" "purple"
token "accent.deep" "blue"
token "success" "green"
token "error" "red"
token "warning" "yellow"
token "info" "aqua"
token "border.focused" "orange"
token "border.unfocused" "bg4"
token "code.keyword" "red"
token "code.function" "green"
token "code.string" "green"
token "code.number" "purple"
token "code.comment" "gray"
token "code.type" "yellow"
token "code.line_number" "bg4"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "orange" "yellow"
gradient "warm" "red" "orange"
gradient "success_gradient" "green" "aqua"
gradient "error_gradient" "red" "orange"
gradient "aurora" "red" "orange" "yellow" "green" "aqua"
