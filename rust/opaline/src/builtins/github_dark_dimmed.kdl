meta name="GitHub Dark Dimmed" author="Primer" variant="dark" version="1.0" description="GitHub's signature dark dimmed theme"

palette "canvas_default" "#22272e"
palette "canvas_overlay" "#2d333b"
palette "canvas_inset" "#1c2128"
palette "canvas_subtle" "#2d333b"
palette "fg_default" "#adbac7"
palette "fg_muted" "#768390"
palette "fg_subtle" "#636e7b"
palette "fg_on_emphasis" "#cdd9e5"
palette "border_default" "#444c56"
palette "border_muted" "#373e47"
palette "blue3" "#6cb6ff"
palette "blue4" "#539bf5"
palette "blue5" "#4184e4"
palette "green3" "#6bc46d"
palette "green4" "#57ab5a"
palette "red3" "#ff938a"
palette "red4" "#f47067"
palette "red5" "#e5534b"
palette "yellow3" "#daaa3f"
palette "yellow4" "#c69026"
palette "orange3" "#f69d50"
palette "orange4" "#e0823d"
palette "purple3" "#dcbdfb"
palette "purple4" "#b083f0"
palette "pink3" "#fc8dc7"
palette "coral3" "#f79981"
palette "syn_comment" "#768390"
palette "syn_constant" "#6cb6ff"
palette "syn_entity" "#dcbdfb"
palette "syn_entity_tag" "#8ddb8c"
palette "syn_keyword" "#f47067"
palette "syn_string" "#96d0ff"
palette "syn_variable" "#f69d50"

token "text.primary" "fg_default"
token "text.secondary" "fg_muted"
token "text.muted" "fg_subtle"
token "text.dim" "border_default"
token "bg.base" "canvas_inset"
token "bg.panel" "canvas_default"
token "bg.code" "canvas_inset"
token "bg.highlight" "canvas_overlay"
token "bg.elevated" "canvas_subtle"
token "bg.active" "border_muted"
token "bg.selection" "canvas_overlay"
token "accent.primary" "blue4"
token "accent.secondary" "purple3"
token "accent.tertiary" "coral3"
token "accent.deep" "blue3"
token "success" "green4"
token "error" "red5"
token "warning" "yellow4"
token "info" "blue3"
token "border.focused" "blue4"
token "border.unfocused" "border_muted"
token "code.keyword" "syn_keyword"
token "code.function" "syn_entity"
token "code.string" "syn_string"
token "code.number" "syn_constant"
token "code.comment" "syn_comment"
token "code.type" "yellow3"
token "code.line_number" "fg_subtle"

style "keyword" fg="accent.primary" bold=#true
style "line_number" fg="code.line_number"
style "cursor_line" bg="bg.highlight"
style "selected" fg="accent.secondary" bg="bg.highlight"
style "active_selected" fg="accent.primary" bg="bg.active" bold=#true
style "focused_border" fg="border.focused"
style "unfocused_border" fg="border.unfocused"
style "success_style" fg="success"
style "error_style" fg="error"
style "warning_style" fg="warning"
style "info_style" fg="info"
style "dimmed" fg="text.dim"
style "muted" fg="text.muted"
style "inline_code" fg="success" bg="bg.code"

gradient "primary" "blue4" "purple3"
gradient "warm" "orange3" "yellow3"
gradient "success_gradient" "green4" "green3"
gradient "error_gradient" "red5" "red3"
gradient "aurora" "blue4" "purple3" "coral3" "green3" "yellow3"
